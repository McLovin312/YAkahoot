# ----------------------------------------------------------------------------
# Lakeside Trivia Night - environment variables
# ----------------------------------------------------------------------------
# Pusher is OPTIONAL.
#
#   * LOCAL PLAY (npm run dev / npm start on your machine):
#     no env vars needed — the game uses its built-in local realtime relay.
#     Players just need to be on the same Wi-Fi and open the join URL / QR
#     code shown on the host screen.
#
#   * DEPLOYED (Vercel etc.): serverless instances can't share the local relay,
#     so you need a free Pusher Channels app: https://pusher.com/channels
#     Create the app, open the "App Keys" tab, and fill in all 4 values.
#
# Values starting with REPLACE_WITH are treated as "not configured".
# ----------------------------------------------------------------------------

# --- Server-side only (keep secret) ---
PUSHER_APP_ID=REPLACE_WITH_app_id
PUSHER_SECRET=REPLACE_WITH_secret

# --- Public (sent to the browser) ---
NEXT_PUBLIC_PUSHER_KEY=REPLACE_WITH_key
NEXT_PUBLIC_PUSHER_CLUSTER=REPLACE_WITH_cluster
