# ----------------------------------------------------------------------------
# Lakeside Trivia Night - environment variables
# ----------------------------------------------------------------------------
# LOCAL PLAY (npm run dev / npm start on your machine):
#   no env vars needed — the game uses its built-in local realtime relay.
#   Players just need to be on the same Wi-Fi and open the join URL / QR code
#   shown on the host screen.
#
# DEPLOYED (Vercel): serverless instances don't share memory, so you need ONE
#   of the realtime backends below. Upstash Redis is the recommended one.
#
# Values starting with REPLACE_WITH are treated as "not configured".
# ----------------------------------------------------------------------------

# --- Option A (recommended): Upstash Redis -----------------------------------
# Create a free database at https://console.upstash.com/ (or add the Upstash
# integration from the Vercel Marketplace, which sets these automatically).
# Copy the REST URL + token from the database page.
UPSTASH_REDIS_REST_URL=REPLACE_WITH_rest_url
UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_rest_token

# --- Option B (alternative): Pusher Channels ---------------------------------
# https://pusher.com/channels -> create app -> "App Keys" tab.
# PUSHER_APP_ID=REPLACE_WITH_app_id
# PUSHER_SECRET=REPLACE_WITH_secret
# NEXT_PUBLIC_PUSHER_KEY=REPLACE_WITH_key
# NEXT_PUBLIC_PUSHER_CLUSTER=REPLACE_WITH_cluster

# --- Optional ----------------------------------------------------------------
# Canonical site URL for share cards / canonical links. Defaults to
# https://lakesideyoungadults.com on Vercel, http://localhost:3000 locally.
# NEXT_PUBLIC_SITE_URL=https://lakesideyoungadults.com
